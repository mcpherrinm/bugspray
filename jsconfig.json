{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun"]
  },
  "include": ["*.js"],
  "exclude": ["node_modules"]
}
